rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 세션 문서 ─────────────────────────────────────────────
    // 코드를 직접 알고 있는 경우에만 읽기/쓰기 허용
    // list(전체 목록 조회)는 차단 → 다른 세션 열람 불가
    match /sessions/{code} {
      allow get:    if true;
      allow list:   if false;
      allow create: if request.resource.data.keys().hasAll(
                        ['createdAt', 'updatedAt', 'buildings', 'states', 'personnelStats', 'log']
                    ) && request.resource.data.buildings.size() <= 3;
      allow update: if resource.data != null;
      allow delete: if false;  // 세션 삭제 금지
    }

    // ── 브리핑 문서 ───────────────────────────────────────────
    // sessionCode 필드 필수 → 세션별 격리
    match /briefings/{id} {
      allow get, list: if true;
      allow create:    if request.resource.data.keys().hasAll(
                           ['sessionCode', 'title', 'tabType', 'createdAt', 'updatedAt', 'fields']
                       );
      allow update:    if resource.data != null;
      allow delete:    if resource.data != null;
    }

    // ── 그 외 모든 경로 차단 ──────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
